[importlinter]
root_packages =
    lora_coverage_api

# ──────────────────────────────────────────────────────────────────────
# Hard invariant: 5-layer architecture trong api-service.
# domain  ←  application  ←  infrastructure  ←  edge
# (mũi tên = chiều phụ thuộc cho phép)
# Vi phạm = build fail trong CI. Không ngoại lệ.
# ──────────────────────────────────────────────────────────────────────

[importlinter:contract:layers]
name = api-service 5-layer separation
type = layers
layers =
    lora_coverage_api.edge
    lora_coverage_api.application
    lora_coverage_api.domain

[importlinter:contract:application-no-infra]
name = application MUST NOT import infrastructure
type = forbidden
source_modules =
    lora_coverage_api.application
forbidden_modules =
    lora_coverage_api.infrastructure

[importlinter:contract:domain-pure]
name = domain MUST NOT import application/infrastructure/edge
type = forbidden
source_modules =
    lora_coverage_api.domain
forbidden_modules =
    lora_coverage_api.application
    lora_coverage_api.infrastructure
    lora_coverage_api.edge

[importlinter:contract:no-leaky-strings]
# Note: import-linter không grep string. Việc cấm các string
# ("postgres", "redis", "valkey", "s3", "stage_4", "GiST", "BRIN")
# trong application/ được enforce qua custom ruff rule + grep CI step
# (xem .github/workflows/ci.yml step "no-leaky-strings").
name = placeholder for string-leakage check (enforced in CI)
type = forbidden
source_modules =
    lora_coverage_api.domain
forbidden_modules =
    lora_coverage_api.edge
