# ──────────────────────────────────────────────────────────────────────
# LoRa Coverage Platform — environment template
# Copy to .env, KHÔNG commit .env (xem .gitignore)
# Theo 12-Factor App: tất cả config qua env, không hardcode.
# ──────────────────────────────────────────────────────────────────────

# ── Runtime mode ─────────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ── Database (PostgreSQL 17 + PostGIS 3.5 + TimescaleDB 2.17) ─────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=lora
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=lora_coverage
DATABASE_URL=postgresql+psycopg://lora:change_me_in_production@db:5432/lora_coverage

# ── Object storage (Cloudflare R2 — S3-compatible) ────────────────────
S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_TILES=lora-tiles
S3_BUCKET_MODELS=lora-models
S3_BUCKET_RAW=lora-raw

# ── Cache (Valkey 8) — rate-limit centralized counter store ───────────
# Compose service `cache` chạy mặc định. URI dưới đây trỏ qua docker
# network → workers chia counter chung (fix divergence khi --workers >= 2).
# APP_ENV=production + empty → startup fail-fast (config validator).
RATE_LIMIT_STORAGE_URI=redis://cache:6379/0

# ── API service ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend (Vite) ───────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_MAP_TILE_URL=https://demotiles.maplibre.org/style.json

# ── ML service ────────────────────────────────────────────────────────
ML_MODEL_VERSION=stage1-itu-p1812-v0.1.0
ML_DEM_PATH=./services/ml-service/data/dem
ML_ONNX_RUNTIME_PROVIDERS=CPUExecutionProvider

# ── Stage 1 ITU-R P.1812 + P.2108 (crc-covlib) — REQUIRED ─────────────
# Folder chứa DEM GeoTIFF tiles (Copernicus GLO-30). crc-covlib auto-detect
# tile theo bbox của link. Container path khác host path — đọc /data/dem
# qua volume mount LORA_DATA_DIR.
LORA_DEM_DIRECTORY=E:/DATN/lora-data/dem
# Surface DEM (DTM + building heights). Rỗng/không set = reuse terrain dir
# (P.1812 surface mode bật nhưng không có building obstruction). Set để dùng
# DSM tiles build bởi scripts/build_dsm.py.
LORA_SURFACE_DEM_DIRECTORY=E:/DATN/lora-data/dem-surface
LORA_ITU_PERCENT_TIME=50.0
LORA_ITU_PERCENT_LOCATION=50.0

# ── Observability (Grafana Cloud free tier) ───────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=lora-coverage-api
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

# ── Sentry error tracking (pre-deploy checklist §8) ───────────────────
# Empty DSN = init no-op (dev); structlog stdout vẫn ghi errors. Production
# set DSN để bắt long-tail single-user crash mà Prometheus rate/latency
# không thấy. tracesSampleRate giữ 0 (chỉ ghi exception, không trace perf).
# Frontend: VITE_SENTRY_DSN là DSN riêng của project FE (Sentry tách project
# theo SDK platform — không share DSN giữa Python + JS).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=development

# ── Geocoding (Address resolution) ────────────────────────────────────
# General donations KHÔNG dùng Google. Chỉ dùng cho donation-marked-google.
GOOGLE_GEOCODING_API_KEY=
NOMINATIM_USER_AGENT=lora-coverage/0.1.0 (contact@example.com)

# ── Identity (plan-auth-v1 §3.1 + plan-auth-v2 step 2) — REQUIRED ─────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=please_change_me_min_32_chars_long_random_string
ACCESS_TTL_MINUTES=15           # access JWT TTL (1..1440)
REFRESH_TTL_DAYS=30             # refresh token TTL (1..365); rotation-on-use

# Refresh cookie (HttpOnly + SameSite=Lax + path=/api/v1/auth).
# SECURE=false cho local http://localhost dev; production HTTPS đặt true.
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax     # lax|strict|none

# ── Linking (plan-auth-v1 §3.3) — REQUIRED ────────────────────────────
# Comma-separated Fernet keys (key đầu = encrypt; tất cả = decrypt fallback).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LINKING_FERNET_KEYS=please_generate_a_real_fernet_key_44_chars_b64_padded=

# ── Auth rate-limit + lockout (plan-auth-v2 step 1) ───────────────────
AUTH_LOGIN_RATE_LIMIT=10/minute
AUTH_REGISTER_RATE_LIMIT=5/hour
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15

# ── Password reset (pre-deploy checklist §2) ──────────────────────────
# TTL ngắn + single-use enforced ở SQL layer (migration 0016).
PASSWORD_RESET_TTL_MINUTES=30
# {token} placeholder được thay bằng plaintext token. URL phải mở
# frontend (KHÔNG phải API origin) → FE đọc query param và mở form reset.
PASSWORD_RESET_URL_TEMPLATE=http://localhost:5173/?reset={token}
AUTH_PASSWORD_RESET_REQUEST_RATE_LIMIT=5/hour
AUTH_PASSWORD_RESET_CONFIRM_RATE_LIMIT=10/hour

# ── SMTP (password reset mailer) ──────────────────────────────────────
# Empty SMTP_HOST = NoOpMailer: log reset URL ra container console (dev).
# Production validator FAIL-FAST nếu empty + APP_ENV=production.
# Local dev với mailpit: SMTP_HOST=localhost SMTP_PORT=1025 SMTP_USE_STARTTLS=false
# Gmail: smtp.gmail.com:587 + app password.
# AWS SES: email-smtp.<region>.amazonaws.com:587 + SES SMTP credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@lora-coverage.local
SMTP_FROM_NAME=LoRa Coverage
SMTP_USE_STARTTLS=true

# ── Coverage endpoint rate limits (per IP) ─────────────────────────────
# Public read endpoints — không auth gate nhưng compute đắt (ITU + geocode).
# Mặc định overrideable; nâng/hạ theo traffic thật quan sát từ /metrics.
# /batch cap thấp vì 1 req ≤500 item → cost amplification; nâng khi /batch
# có auth gate (per-user quota thay per-IP).
COVERAGE_PREDICT_RATE_LIMIT=30/minute
COVERAGE_LOOKUP_RATE_LIMIT=30/minute
COVERAGE_BATCH_RATE_LIMIT=1/minute
# CSV upload survey (POST /me/uploads/csv) per user — cap thấp vì tốn DB
# + ITU compute mỗi row khi submit_to_community.
ME_CSV_UPLOAD_RATE_LIMIT=10/hour

# ── ChirpStack per-user webhook ingest ────────────────────────────────
# Public origin của API mà ChirpStack server-to-server kết nối tới. FE concat
# với token để hiển thị URL "Copy". KHÔNG có default cho production: validator
# fail-fast nếu APP_ENV=production + empty.
WEBHOOK_BASE_URL=http://localhost:8000
# slowapi rate limit per-token (count/period). 600/min = trần thoải mái
# cho deployment vài chục device (ChirpStack v4 mặc định <100 msg/s/app).
CHIRPSTACK_WEBHOOK_RATE_LIMIT=600/minute

# ── Bidirectional link budget device defaults ─────────────────────────
# Áp dụng khi PredictRequest không gửi field. tx_power capped 14 dBm
# bởi AS923-2 regional cap (domain validation reject > 14).
DEFAULT_DEVICE_TX_POWER_DBM=14.0
DEFAULT_DEVICE_TX_ANTENNA_GAIN_DBI=2.0
DEFAULT_DEVICE_RX_ANTENNA_GAIN_DBI=0.0

# ── Stage 2 (ML) — api-service → ml-service HTTP ──────────────────────
# Service đang handoff cho dev mới rebuild. Để empty → api-service chạy
# Stage1-only (no ML refinement). Khi dev có model mới, set:
#   STAGE2_PREDICT_BASE_URL=http://ml-service:8001
STAGE2_PREDICT_BASE_URL=
STAGE2_TIMEOUT_SECONDS=0.5

# ── ML training + serving (lora_ml_predict.config.Settings) ───────────
# Prefix LORA_ — đọc bởi training script + ml-service container.
LORA_DB_URL=postgresql://lora_user:lora_pass_2024@localhost:5432/lora_coverage
LORA_DEM_PATH=E:/DATN/lora-data/dem/copernicus_glo30_danang.tif
# Bắc Bộ DEM (HP, HD, Hà Nội) — dùng cho Stage 1 validation HP/HD.
LORA_DEM_PATH_NORTH_VN=E:/DATN/lora-data/dem/copernicus_glo30_north_vn.tif
LORA_URBANIZATION_PATH=E:/DATN/lora-data/osm/urbanization_vn.tif
LORA_ENV_PROFILE=suburban
# Bearer token shared giữa api-service ↔ ml-service.
# DEV ONLY — production phải replace bằng `secrets.token_urlsafe(32)`.
LORA_STAGE2_AUTH_TOKEN=stage2-dev-please-change

# Host dir chứa DEM + OSM rasters (mount read-only vào ml-service).
LORA_DATA_DIR=E:/DATN/lora-data
