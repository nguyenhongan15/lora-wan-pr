# ──────────────────────────────────────────────────────────────────────
# Test environment — committed vào git có chủ đích.
#
# File này được pytest auto-load qua `tests/conftest.py`.
#
# DB test dùng USER + PASSWORD RIÊNG (`lora_test_user` / `test_only_no_secrets`)
# tách hoàn toàn khỏi DB dev (`lora_user` / *secret*). Nếu credential này
# lộ ra (committed lên public repo) cũng chỉ ảnh hưởng DB test rỗng,
# không liên quan gì DB dev của bất cứ ai.
#
# Setup lần đầu — xem services/api-service/README.md §Test.
# ──────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql+psycopg://lora_test_user:test_only_no_secrets@localhost:5432/lora_coverage_test
APP_ENV=test
LOG_LEVEL=WARNING

# Identity — deterministic test secret (committed; chỉ dùng cho DB test rỗng).
JWT_SECRET=test_only_jwt_secret_deterministic_must_be_at_least_32_chars
ACCESS_TTL_MINUTES=60
REFRESH_TTL_DAYS=7

# Linking — deterministic Fernet key cho test (không production).
LINKING_FERNET_KEYS=ItDfz1U9l6dmW3_f-_A9oJtM-wV5dOV8ya3kIv94utg=


# Stage 1 ITU-R P.1812 backend — DEM directory cho test (file không cần tồn tại
# real ở môi trường unit test; tests dùng FakeBackend, không gọi crc-covlib).
# Path placeholder thoả validation 'is_dir()' khi Settings() được build qua
# default — chỉ tests gọi backend thật mới cần DEM thật.
LORA_DEM_DIRECTORY=./tests/__fake_dem_dir__
LORA_ITU_PERCENT_TIME=50.0
LORA_ITU_PERCENT_LOCATION=50.0

