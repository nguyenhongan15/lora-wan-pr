# Build context exclusions. Dockerfile context = repo root (cần workspace
# pyproject + vendor/crc-covlib wheel + src của workspace members), nên thay
# vì whitelist (dễ miss new file), blacklist các dir to + irrelevant.
#
# Test: `docker build --progress=plain .` → log "transferring context: ...MB"
# trước khi áp dụng file này >1 GB, sau khi áp dụng <50 MB.

# VCS
.git
.gitignore
.gitattributes

# Frontend node deps + build output
apps/web-app/node_modules
apps/web-app/dist
apps/web-app/.vite
node_modules

# Python tooling
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
.venv
.venv-*
**/.venv

# Data (DEM/DSM tiles, OSM exports — mount qua volume, không cần trong context)
data
cache

# Coverage artifacts (mount riêng cho celery-worker khi cần)
apps/web-app/public/coverage/minsf/*.tif

# Docs + IDE
docs
.vscode
.idea
*.md
!services/ml-service/README.md
!packages/sdk-python/README.md

# Misc
*.log
.env
.env.*
!.env.example
docker-compose.override.yml
