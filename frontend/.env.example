# ── Frontend Environment Variables ────────────────────────────
# Copy thành `.env` và điền giá trị thật.
# KHÔNG commit `.env` lên git (đã có trong .gitignore).
#
# Lưu ý: Vite chỉ expose biến có prefix `VITE_` ra client code.

# ── Backend API ──────────────────────────────────────────────
# URL gốc của backend, bao gồm cả /api/v1 prefix
VITE_API_BASE=http://localhost:8000/api/v1

# ── Mapbox ───────────────────────────────────────────────────
# Public token (pk.*) — lấy tại https://account.mapbox.com/access-tokens
VITE_MAPBOX_TOKEN=pk.xxx
