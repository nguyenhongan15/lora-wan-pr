# ──────────────────────────────────────────────────────────────────────
# Prometheus scrape config — example cho deployment 1-VPS.
# Copy sang /etc/prometheus/prometheus.yml trên host monitoring (cùng
# VPS hoặc tách riêng tuỳ scale).
#
# Mount: alerts.yml phải được Prometheus đọc được; mặc định trỏ
# rule_files vào /etc/prometheus/rules/*.yml.
# ──────────────────────────────────────────────────────────────────────

global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: lora-coverage-vps
    env: production

rule_files:
  - /etc/prometheus/rules/*.yml

# Alertmanager — chạy cùng host. Nếu chưa dùng AM thì xoá block này;
# alert rules vẫn evaluate, chỉ không push notification.
alerting:
  alertmanagers:
    - static_configs:
        - targets: ["alertmanager:9093"]

scrape_configs:
  - job_name: api-service
    metrics_path: /metrics
    static_configs:
      # api-service chạy trong docker network với compose stack.
      # Nếu Prometheus chạy ngoài stack → đổi sang host.docker.internal:8000
      # hoặc public ingress (chú ý: /metrics phải block khỏi public — chỉ
      # private network, xem metrics.py docstring).
      - targets: ["api-service:8000"]
        labels:
          service: api-service
