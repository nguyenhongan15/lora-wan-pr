# ── .env.example ──────────────────────────────────────────────
# Copy thành `.env` và điền giá trị thật.
# KHÔNG commit `.env` lên git.

# ── Database (Factor 4: Backing Service) ────────────────────
DATABASE_URL=postgresql+asyncpg://lora:lora@localhost:5432/lora_db

# ── App ─────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_NAME="LoRa Coverage API"
API_PREFIX=/api/v1
LOG_LEVEL=info               # debug | info | warning | error

# ── CORS (cors.pdf Rule 1: KHÔNG dùng *, whitelist tường minh) ──
# JSON array — mỗi origin là 1 phần tử string
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173", "https://192.168.1.3:5173"]
CORS_MAX_AGE=86400

# ── Webhook security ───────────────────────────────────────
# Shared secret giữa backend và ChirpStack để verify HMAC signature.
# Đây KHÔNG phải auth user, chỉ để xác minh nguồn gốc payload.
# Sinh: openssl rand -hex 32
WEBHOOK_SECRET=

# ── ML ──────────────────────────────────────────────────────
ML_MODEL_DIR=ml_models
DEM_DIR=../DEM
GP_MAX_SAMPLES=300

# ── Mapbox (frontend dùng; backend chỉ cần khi generate tiles) ──
MAPBOX_PUBLIC_TOKEN=pk.xxx

# ── LoRaWAN defaults ────────────────────────────────────────
DEFAULT_FREQ_MHZ=868.0
DEFAULT_SF=9

# ── External APIs ──────────────────────────────────────────
LPWAN_BASE_URL=https://api.lpwanmapper.com

